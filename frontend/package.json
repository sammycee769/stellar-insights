{
  "name": "stellar-insights",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:timed": "node -e \"const s=Date.now();const {execSync}=require('child_process');try{execSync('next build',{stdio:'inherit'})}finally{const ms=Date.now()-s;const mins=Math.floor(ms/60000);const secs=((ms%60000)/1000).toFixed(1);console.log('\\n⏱  Build time: '+mins+'m '+secs+'s ('+ms+'ms)')}\"",
    "build:timed": "node -e \"const s=Date.now();const {execSync}=require('child_process');try{execSync('next build',{stdio:'inherit'})}finally{const ms=Date.now()-s;console.log('\\nBuild time: '+(ms/1000).toFixed(1)+'s')}\"",
    "start": "next start",
    "analyze": "ANALYZE=true next build && node scripts/analyze-bundle.mjs",
    "lint": "eslint",
    "lint:a11y": "eslint --ext .tsx,.ts --rule 'jsx-a11y/*: error' src/",
    "test": "vitest",
    "test:a11y": "vitest run --reporter=verbose src/components/__tests__/accessibility.a11y.test.tsx src/components/__tests__/accessibility.test.tsx",
    "test:ui": "vitest --ui",
    "test:contrast": "node scripts/validate-colors.mjs",
    "benchmark": "node benchmarks/api.bench.mjs",
    "benchmark:save-baseline": "SAVE_BASELINE=true node benchmarks/api.bench.mjs",
    "test:benchmarks": "node --test benchmarks/api.bench.test.mjs",
    "test:i18n": "vitest run src/__tests__/i18n.test.ts",
    "i18n:coverage": "vitest run src/__tests__/i18n.test.ts --reporter=verbose"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "5.2.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^8.0.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "@tanstack/react-query": "5.100.5",
    "@tanstack/react-query-devtools": "5.100.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force-3d": "^3.0.6",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.1",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.17.0",
    "next": "^16.2.4",
    "next-intl": "^4.13.0",
    "next-pwa": "^5.6.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-force-graph-2d": "1.29.1",
    "react-hook-form": "7.73.1",
    "recharts": "3.7.0",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "autocannon": "^8.0.0",
    "axe-core": "^4.11.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "jest-axe": "9.0.0",
    "jsdom": "28.1.0",
    "prisma": "6.19.2",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.5",
    "vitest-axe": "1.0.0-pre.5"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
  "overrides": {
    "dompurify": "^3.4.1"
  }
}
