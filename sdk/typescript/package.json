{
  "name": "@stellar-insights/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Stellar Insights API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["stellar", "sdk", "payments", "analytics", "retry-backoff"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "8.0.2",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
